{
  "name": "@donate/api",
  "version": "0.1.0",
  "private": true,
  "description": "Donate Protocol REST API server",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@donate/auth": "workspace:*",
    "@donate/database": "workspace:*",
    "@donate/utils": "workspace:*",
    "@fastify/cors": "^8.5.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^6.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "bcrypt": "^5.1.1",
    "fastify": "^4.27.0",
    "jsonwebtoken": "^9.0.2",
    "pino": "^8.20.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^6.3.3",
    "tsx": "^4.7.0",
    "typescript": "^5.4.2",
    "vitest": "^1.0.4"
  }
}
