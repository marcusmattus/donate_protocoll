# ============================================================================
# Donate Protocol - Environment Configuration
# ============================================================================

# Environment
NODE_ENV=development

# Database
DATABASE_URL="postgresql://donate:donate@localhost:5432/donate_protocol?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT Authentication
JWT_SECRET="your-secret-key-CHANGE-IN-PRODUCTION"

# External Services
# -----------------

# Plaid (for broker connections)
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox # sandbox, development, production

# Stripe (for payouts and payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# SendGrid (for emails)
SENDGRID_API_KEY=SG.your_sendgrid_key
SENDGRID_FROM_EMAIL=noreply@donate-protocol.com

# AWS S3 (for object storage)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=us-east-1
AWS_S3_BUCKET=donate-protocol-storage

# Monitoring & Logging
# ---------------------

# Datadog
DATADOG_API_KEY=your_datadog_key
DATADOG_APP_KEY=your_datadog_app_key

# Sentry
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id

# Application URLs
# ----------------

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
ADMIN_URL=http://localhost:3002

# API Configuration
# -----------------

# API rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3002

# Feature Flags
# -------------

FEATURE_WAITLIST_ENABLED=true
FEATURE_PARTNER_SIGNUP_ENABLED=true
FEATURE_CRYPTO_DONATIONS_ENABLED=false

# Development
# -----------

# Enable debug logging
DEBUG=donate:*

# Prisma
PRISMA_LOG_LEVEL=info

# Disable telemetry
DO_NOT_TRACK=1
